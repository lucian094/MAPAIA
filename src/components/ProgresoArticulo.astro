---
interface Props {
  estacionId: string;
  nombre: string;
}

const { estacionId } = Astro.props;
---

<div class="progreso-articulo" data-estacion={estacionId} hidden>
  <button type="button" class="btn-visita" aria-pressed="false">
    Marcar como visitada
  </button>
  <p class="aviso-privacidad">Tu progreso se guarda solo en este navegador.</p>
</div>

<script>
  import { alternarVisitada, leerVisitadas } from '../lib/progreso';

  const contenedores = document.querySelectorAll<HTMLElement>('.progreso-articulo[data-estacion]');

  for (const cont of contenedores) {
    const id = cont.dataset.estacion;
    if (!id) continue;

    const boton = cont.querySelector<HTMLButtonElement>('.btn-visita');
    if (!boton) continue;

    // Revelar el contenedor ahora que JS está disponible.
    cont.hidden = false;

    function pintar(visitada: boolean): void {
      if (!boton) return;
      if (visitada) {
        boton.textContent = 'Visitada ✓ (quitar)';
        boton.setAttribute('aria-pressed', 'true');
      } else {
        boton.textContent = 'Marcar como visitada';
        boton.setAttribute('aria-pressed', 'false');
      }
    }

    // Estado inicial.
    pintar(leerVisitadas().includes(id));

    boton.addEventListener('click', () => {
      const ahora = alternarVisitada(id);
      pintar(ahora);
    });
  }
</script>

<style>
  .progreso-articulo {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .btn-visita {
    font: inherit;
    font-size: 0.9rem;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.4rem;
    padding: 0.45rem 1rem;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      background 0.15s ease;
  }

  .btn-visita:hover {
    border-color: var(--text-muted);
  }

  .btn-visita:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .btn-visita[aria-pressed='true'] {
    background: var(--accent);
    color: var(--accent-text);
    border-color: var(--accent);
  }

  .btn-visita[aria-pressed='true']:hover {
    border-color: var(--text-muted);
  }

  .aviso-privacidad {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.78rem;
  }
</style>
