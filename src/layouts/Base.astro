---
import '../styles/theme.css';
import { unirRuta } from '../lib/rutas';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Modelo de Adopción Progresiva de Agentes de Inteligencia Artificial',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a class="logo" href={base}><span aria-hidden="true">🚇</span> MAPAIA</a>
      <nav>
        <a href={unirRuta(base, 'glosario/')}>Glosario</a>
        <a href="https://github.com/lucian094/MAPAIA">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        MAPAIA — contenido abierto bajo licencia CC BY-NC 4.0 · Luciano Iván Alvarez
      </p>
    </footer>
  </body>
</html>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  nav {
    display: flex;
    gap: 1.25rem;
  }

  nav a {
    color: var(--text-muted);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--text);
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 1rem 1.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    text-align: center;
  }
</style>
